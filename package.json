{
  "name": "clipcut",
  "version": "1.0.0",
  "description": "Instant replay screen recorder with global hotkey",
  "main": "src/main/index.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:main": "tsc && electron dist/main/index.js",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && tsc",
    "dist": "npm run build && electron-builder",
    "rebuild:native": "node-gyp rebuild --directory src/native"
  },
  "dependencies": {
    "electron": "^30.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "bindings": "^1.5.0",
    "node-addon-api": "^8.2.1",
    "regedit": "^5.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron-builder": "^24.13.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vite": "^5.3.0"
  }
}